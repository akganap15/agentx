# ============================================================
# SMB-in-a-Box / T-CHai  —  Environment Variables Example
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------ Anthropic ------
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-sonnet-4-6

# ------ T-Mobile / SMS ------
# Used for T-Mobile network-native SMS gateway
TMOBILE_SMS_API_KEY=your-tmobile-sms-api-key
TMOBILE_SMS_API_URL=https://api.t-mobile.com/sms/v1

# ------ Retell AI ------
RETELL_API_KEY=your-retell-api-key
RETELL_AGENT_ID=your-retell-agent-id
VOICE_PROVIDER=openai_realtime

# Twilio — SMS fallback + Voice AI
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Voice AI — public URL Twilio posts to (use ngrok for local dev)
# ngrok http 8100  →  copy the https URL here
VOICE_WEBHOOK_BASE_URL=https://your-ngrok-id.ngrok-free.app
BUSINESS_NAME=Andy Plumbing

# ------ Google APIs ------
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key
GOOGLE_CALENDAR_ID=primary
GOOGLE_REVIEWS_API_KEY=your-google-reviews-api-key
GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------ SendGrid ------
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@smbinabox.com
SENDGRID_FROM_NAME=SMB-in-a-Box

# ------ Database ------
# For production: postgresql+asyncpg://user:password@host:5432/smbinabox
DATABASE_URL=postgresql+asyncpg://smb:smb@localhost:5432/smbinabox

# ------ Hackathon / Demo flags ------
# Set to true to skip real DB and use in-memory store (fast demo startup)
USE_IN_MEMORY_STORE=true
# The business ID pre-loaded in the in-memory store
DEMO_BUSINESS_ID=demo-petes-plumbing

# ------ App ------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ------ CORS ------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
